# Environment & secrets
.env
*.env.local

# Maven
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# IDE
.idea/
*.iml
*.iws
.vscode/
*.swp
*.swo

# Spring Boot
spring-shell.log

# OS
.DS_Store
Thumbs.db

# Docker volumes (local dev data)
docker/postgres/data/

# Build artifacts
*.jar
*.war
*.class

# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# Test output
surefire-reports/
jacoco/

# Claude Code local settings (user-specific)
.claude/settings.local.json

# Ad-hoc scratch files
tmp_*.py
/user_maxdate.csv

# Research / paper / evaluation artifacts — kept locally only.
# All files needed to compile and submit the paper, plus eval outputs,
# live under research/ and are not published in the public codebase repo.
research/
# Task tracking used by Claude Code tooling (local only)
tasks/

# Optional: the LaTeX build archives in arxiv_submission/ can always
# be regenerated from artha.tex; comment out these lines if you want
# to version-control the packaged artifacts.
arxiv_submission/artha-arxiv.tar.gz
arxiv_submission/artha-arxiv.zip

# Investments data cache — fetched from Yahoo Finance, regenerable.
# data/fetchers/ is code and stays tracked.
data/investments/

# Banking generator output — regenerable from generate_artha_data_v2.py.
artha_users_v2.json

# Eval-harness outputs — kept locally; not part of the public codebase.
eval_results/

# BLS PUMD raw archives and extracts — ~700 MB. Re-download from the BLS
# Consumer Expenditure Survey PUMD page (manual browser download; BLS WAF
# blocks automated fetches). data/calibration/pull_bls_ces.py rebuilds
# archetype_profiles.json from these files.
data/calibration/raw/
