# ════════════════════════════════════════════════════
#  FinWise AI Agent — Environment Variables Template
#  Copy to .env and fill in your actual values.
#  NEVER commit .env to git.
# ════════════════════════════════════════════════════

# ── Anthropic (REQUIRED) ─────────────────────────────
# Get at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Plaid (REQUIRED for bank data) ───────────────────
# Get at: https://dashboard.plaid.com/team/keys
# Sandbox is free — no real banks connected
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret

# ── Alpha Vantage (market data) ───────────────────────
# Free tier works for prototype: https://www.alphavantage.co/support/#api-key
# Use "demo" to skip registration initially
ALPHA_VANTAGE_API_KEY=demo

# ── Database ─────────────────────────────────────────
DB_USERNAME=finwise
DB_PASSWORD=finwise

# ── JWT Auth ─────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-with-256-bit-random-string-generated-by-openssl

# ── Email Notifications ───────────────────────────────
# For local dev, use Mailhog: docker compose --profile debug up
# For production, use AWS SES credentials
MAIL_HOST=localhost
MAIL_USERNAME=
MAIL_PASSWORD=

# ── Notifications ─────────────────────────────────────
NOTIFICATION_FROM_EMAIL=noreply@finwise.local
